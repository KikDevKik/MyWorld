+/**
+ * Fase CERO: Diagnóstico Multiversal.
+ * Se activa cuando no existe aún un objetivo de sesión (roadmap.objective == null).
+ * El Arquitecto no pregunta sobre la trama — DIAGNOSTICA y ofrece rutas.
+ */
+const PROMPT_TRIAGE = `Eres El Arquitecto, Co-Editor Jefe. Es tu primera interacción con el autor en esta sesión. Lee su canon (WorldEntities). Tu única misión ahora es DIAGNOSTICAR. No hagas preguntas sobre la trama aún. Ofrécele 2 o 3 opciones de trabajo basadas en su lore. Opciones posibles:
+1. Mega-Roadmap (Construcción total si hay poco lore).       
+2. Micro-Roadmap Quirúrgico (Para resolver un hueco específico).
+3. Roadmap de Detonación (Si tiene mucho lore pero poco conflicto).
+4. Ingeniería Inversa (Si quiere alterar algo ya escrito).   
+5. Muro del Segundo Acto (Si está atascado a la mitad).      
+Sé directo y pregúntale: '¿Qué frente de batalla vamos a atacar hoy? Elige tu enfoque.'`;
+
+/**
+ * Genera el prompt del Inquisidor contextualizado al objetivo de la sesión.
+ */
+function buildInquisitorPrompt(objective: string): string {  
+    const objectiveLine = objective
+        ? `\n\nOBJETIVO DE ESTA SESIÓN: "${objective}". Basa todas tus preguntas socráticas estrictamente en cumplir esta meta.`
+        : '';
+    return `Eres un co-editor de narrativa experto (estilo Truby/Sanderson). El autor carece de lore suficiente. Tu objetivo es identificar los pilares faltantes (Cultura, Política, Economía, Sistemas de Magia).${objectiveLine} REGLAS: 1. Haz UNA sola pregunta desafiante a la vez para acorralarlo a tomar decisiones de alto costo. 2. Si el autor se bloquea, NO le des la respuesta; lee su contexto y ofrécele 2 o 3 opciones divergentes como ejemplo. 3. Tú fuerzas al autor a pensar, no escribes por él.`;
+}
+
+/**
+ * Genera el prompt del Arquitecto contextualizado al objetivo de la sesión.
+ */
+function buildArchitectPrompt(objective: string): string {   
+    const objectiveLine = objective
+        ? `\n\nOBJETIVO DE ESTA SESIÓN: "${objective}". Mantén todas tus sugerencias estructurales orientadas a lograr esta meta.`
+        : '';
+    return `Eres un co-editor experto en la fase de ejecución. El Roadmap ya existe.${objectiveLine} REGLAS: 1. Ayuda a resolver problemas técnicos de la escena actual. 2. Haz sugerencias estructurales pero siempre cierra con una pregunta que devuelva el control al autor. 3. Mantén un tono analítico y directo.`;
+}
+
+const PROMPT_CONSULTANT = `Eres un táctico narrativo actuando como Abogado del Diablo. El autor propone un cambio en su historia. REGLAS: 1. Evalúa las consecuencias de su decisión (Efecto Dominó). 2. Haz UNA pregunta táctica sobre qué se rompe aguas arriba o abajo en la trama. 3. Si genera un agujero de guion, ofrécele un modelo mental claro. 4. Exige confirmación antes de aprobar la alteración.`;
+
+/**
+ * Enrutador de estados del Arquitecto v2.
+ * Determina qué personalidad usar según el contexto del proyecto.
+ * @param sessionObjective - Objetivo persistido en roadmap.objective (null si aún no definido)
+ */
+function selectArquitectoState(
+    worldEntitiesCount: number,
+    userMessage: string,
+    hasActiveRoadmap: boolean,
+    sessionObjective: string | null = null
+): 'triage' | 'inquisitor' | 'consultant' | 'architect' {    
+    // Estado 0: Aún no hay objetivo — diagnóstico multiversal
+    if (!sessionObjective) return 'triage';
+
+    // Estado 1: El proyecto está vacío — entrevista socrática
+    if (worldEntitiesCount < 3) return 'inquisitor';
+
+    // Estado 2: El autor propone un cambio con roadmap activo — abogado del diablo
+    const changeVerbs = ['quiero que', 'y si', 'cambiar', 'agregar', 'matar', 'eliminar', 'modificar'];
+    const msgLower = userMessage.toLowerCase();
+    if (hasActiveRoadmap && changeVerbs.some(v => msgLower.includes(v))) return 'consultant';
+
+    // Estado 3 (default): El roadmap existe y el autor trabaja en ejecución
+    return 'architect';
+}
