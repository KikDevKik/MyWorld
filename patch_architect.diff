+=== DECISIONES DEL AUTOR(Sesión Socrática) ===
+    ${sessionContext || 'Sin decisiones documentadas.'}      
+`.trim();
+
+        const genAI = new GoogleGenerativeAI(getAIKey(request.data, googleApiKey.value()));
+
+        const roadmapPrompt = `
+Eres El Arquitecto.El autor ya terminó su entrevista socrática.Ahora tienes suficiente información para cristalizar el mapa narrativo de su proyecto.
+
+CONTEXTO COMPLETO:
+${fullContext.substring(0, 50000)}
+
+Genera el Roadmap narrativo del proyecto.Responde SOLO con JSON válido en esta estructura exacta:
+{
+    "items": [
+        {
+            "code": "ERR-001",
+            "severity": "critical",
+            "title": "Título del problema",
+            "description": "Descripción clara",
+            "relatedFiles": [],
+            "category": "continuidad"
+        }
+    ],
+        "roadmapCards": [
+            {
+                "id": "card-001",
+                "title": "Título de la fase",
+                "description": "Descripción de los objetivos de esta fase",
+                "order": 0,
+                "phase": "fundacion",
+                "status": "active",
+                "missions": [],
+                "dominoLinks": [],
+                "impactScore": 0
+            }
+        ]
+}
+
+REGLAS ESTRÍCTAS:
+- Genera entre 3 y 5 tarjetas secuenciales(fases posibles: fundacion, conflicto, desarrollo, climax, resolucion).
+- Solo la primera tarjeta(order: 0) tiene status 'active'.Las demás 'locked'.
+- BASA LAS TARJETAS ESTRICTAMENTE EN LA CONVERSACIÓN y las decisiones que acaba de tomar el autor.Mínimo grado de alucinación narrativa.
+- Cada tarjeta representa una etapa narrativa concreta.      
+- En 'items', genera pendingItems(misiones) derivados del progreso del roadmap.
+- Detecta el idioma del contenido y responde en ese mismo idioma.
+        `;
+
+        const result = await smartGenerateContent(genAI, roadmapPrompt, {
+            useFlash: true,
+            jsonMode: true,
+            temperature: 0.3, // Temp baja para anclar al canon
+            contextLabel: 'ArquitectoGenerateRoadmapUnified',
+        });
+
+        let pendingItems: PendingItem[] = [];
+        let roadmapCards: RoadmapCard[] = [];
+
+        if (result.text) {
+            const parsed = parseSecureJSON(result.text, 'ArquitectoGenerateRoadmapUnified');
+            if (parsed && !parsed.error) {
+                pendingItems = parsed.items || [];
+
+                const now = new Date().toISOString();        
+                roadmapCards = (parsed.roadmapCards || []).map((card: any, idx: number) => ({
+                    id: card.id || `card - ${Math.random().toString(36).substring(2, 7)} `,
+                    title: card.title || 'Fase sin título',  
+                    description: card.description || '',     
+                    status: (idx === 0 ? 'active' : 'locked') as CardStatus,
+                    order: idx, // Forzamos serialización ordenada
+                    phase: card.phase || 'fundacion',        
+                    missions: card.missions || [],
+                    dominoLinks: card.dominoLinks || [],     
+                    impactScore: card.impactScore ?? 0,      
+                    createdAt: now,
+                    updatedAt: now,
+                }));
+
+                // 3. WRITE BATCH ATÓMICO: Exorcismo y Persistencia
+                if (roadmapCards.length > 0) {
+                    const batch = db.batch();
+                    const roadmapBaseRef = sessionRef.collection('architect').doc('roadmap').collection('cards');
+
+                    // Borrar tarjetas fantasmas previas     
+                    const existingCardsSnap = await roadmapBaseRef.get();
+                    existingCardsSnap.docs.forEach(doc => {  
+                        batch.delete(doc.ref);
+                    });
+
+                    // Inyectar tarjetas nuevas
+                    for (const card of roadmapCards) {       
+                        batch.set(roadmapBaseRef.doc(card.id), card);
+                    }
+
+                    // Actualizar sesión general
+                    batch.set(sessionRef, {
+                        arquitectoState: 'architect',        
+                        pendingItems,
+                        updatedAt: new Date().toISOString(), 
+                    }, { merge: true });
+
+                    // Sobrescribir project_config con la nueva realidad (elimina fantasmas en UI)
+                    const projectConfigRef = db.collection('users').doc(userId).collection('profile').doc('project_config');
+                    batch.set(projectConfigRef, {
+                        arquitectoCachedPendingItems: pendingItems,
+                        lastArquitectoAnalysis: new Date().toISOString()
+                    }, { merge: true });
+
+                    await batch.commit();
+                    logger.info(`🗺️[ARQUITECTO] Generación Attómica Exitosa.${roadmapCards.length} tarjetas cristalizadas, historial y project_config limpios.`);
+                }
+            }
+        }
+
+        return { ready: true, roadmapCards, pendingItems };  
+    }
+);
