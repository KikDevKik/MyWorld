rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Bloqueo total por defecto (nadie accede a lo no especificado)
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /profile/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /WorldEntities/{entityId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /forge_sessions/{sessionId} {
        allow read, write, delete: if request.auth != null && request.auth.uid == userId;

        match /{document=**} {
          allow read, write, delete: if request.auth != null && request.auth.uid == userId;
        }
      }

      match /muse_sessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        match /messages/{messageId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

      match /projects/{projectId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        match /{subcollection=**} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

      match /characters/{charId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /audit_cache/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /file_locks/{fileId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /system_secrets/{doc} {
        allow read: if false;
        allow write: if false;
      }
    }

    match /public_certificates/{certId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
